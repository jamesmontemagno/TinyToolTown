# Supabase client-side configuration (required for GitHub auth + synced favorites)
PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key

# Supabase Auth -> GitHub OAuth redirect URLs should include:
# http://localhost:4321/auth/callback/
# https://tinytooltown.com/auth/callback/
