---
const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="logo">
      <span class="logo-icon">🏘️</span>
      <span class="logo-text">Tiny Tool Town</span>
    </a>
    <nav class="nav">
      <a href="/tools/" class:list={["nav-link", { active: currentPath.startsWith('/tools') }]}>Browse</a>
      <a href="/favorites/" class:list={["nav-link", { active: currentPath === '/favorites/' }]}>Favorites <span class="favorites-count" id="favorites-count" hidden>0</span></a>
      <a href="/submit/" class:list={["nav-link", { active: currentPath === '/submit/' }]}>Submit</a>
      <a href="/about/" class:list={["nav-link", { active: currentPath === '/about/' }]}>About</a>
      <button class="auth-toggle" id="auth-toggle" aria-label="Sign in with GitHub">Sign in</button>
      <a href="https://github.com/shanselman/TinyToolTown" class="nav-link github-link" target="_blank" rel="noopener">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
      </a>
      <button class="theme-toggle" id="theme-toggle" title="Toggle theme" aria-label="Toggle theme">
        <span class="theme-icon" id="theme-icon">🌙</span>
      </button>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-header-bg, rgba(15, 14, 23, 0.85));
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--color-border);
    padding: 1rem 0;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 800;
    font-size: 1.25rem;
    color: var(--color-text);
    text-decoration: none;
  }

  .logo:hover {
    color: var(--color-primary);
  }

  .logo-icon {
    font-size: 1.5rem;
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .nav-link {
    color: var(--color-text);
    opacity: 0.7;
    font-weight: 500;
    font-size: 0.95rem;
    transition: color 0.2s, opacity 0.2s;
    text-decoration: none;
  }

  .nav-link:hover, .nav-link.active {
    color: var(--color-primary);
    opacity: 1;
  }

  .github-link {
    display: flex;
    align-items: center;
  }

  @media (max-width: 640px) {
    .nav { gap: 1rem; }
    .logo-text { display: none; }
  }

  .theme-toggle {
    background: none;
    border: 1px solid var(--color-border);
    border-radius: 50%;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
    padding: 0;
  }

  .theme-toggle:hover {
    border-color: var(--color-primary);
    transform: rotate(20deg);
  }

  .theme-icon {
    font-size: 1.1rem;
    line-height: 1;
  }

  .auth-toggle {
    border: 1px solid var(--color-border);
    background: var(--color-bg-card);
    color: var(--color-text);
    border-radius: 999px;
    padding: 0.35rem 0.8rem;
    font-size: 0.82rem;
    font-weight: 600;
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s, transform 0.2s;
  }

  .auth-toggle:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
    transform: translateY(-1px);
  }

  .auth-toggle:disabled {
    opacity: 0.55;
    cursor: not-allowed;
    transform: none;
  }

  .favorites-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.25rem;
    height: 1.25rem;
    margin-left: 0.35rem;
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 700;
    background: rgba(255, 80, 122, 0.2);
    color: #ff8cab;
    padding: 0 0.3rem;
  }
</style>

<script>
  import { getCurrentSession, isSupabaseConfigured, onAuthStateChange, signInWithGitHub, signOut } from '../lib/auth';
  import { getFavoriteIds, onFavoritesChanged } from '../lib/favorites';

  const themes = ['dark', 'light', 'geocities'];
  const icons: Record<string, string> = { dark: '🌙', light: '☀️', geocities: '🌈' };

  function getTheme(): string {
    const saved = localStorage.getItem('ttt-theme');
    if (saved) return saved;
    return window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
  }

  function setTheme(theme: string) {
    document.documentElement.setAttribute('data-theme', theme === 'dark' ? '' : theme);
    if (theme === 'dark') document.documentElement.removeAttribute('data-theme');
    localStorage.setItem('ttt-theme', theme);
    const icon = document.getElementById('theme-icon');
    if (icon) {
      const nextTheme = themes[(themes.indexOf(theme) + 1) % themes.length];
      icon.textContent = icons[nextTheme];
    }
  }

  // Init on load — but don't override a tool-specific theme set by the page
  const toolTheme = document.documentElement.getAttribute('data-theme');
  if (!toolTheme || themes.includes(toolTheme)) {
    setTheme(getTheme());
  } else {
    // Tool has a custom theme — just update the toggle icon
    const icon = document.getElementById('theme-icon');
    if (icon) icon.textContent = icons[themes[0]];
  }

  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const current = getTheme();
    const next = themes[(themes.indexOf(current) + 1) % themes.length];
    setTheme(next);
  });

  const authButton = document.getElementById('auth-toggle') as HTMLButtonElement | null;
  const favoritesCount = document.getElementById('favorites-count') as HTMLSpanElement | null;
  const authEnabled = isSupabaseConfigured();
  let signedIn = false;

  function syncFavoritesCount() {
    if (!favoritesCount) return;
    const count = getFavoriteIds().length;
    favoritesCount.hidden = count === 0;
    favoritesCount.textContent = String(count);
  }

  function syncAuthButton(label?: string) {
    if (!authButton) return;
    if (!authEnabled) {
      authButton.textContent = 'Auth off';
      authButton.disabled = true;
      authButton.title = 'Set PUBLIC_SUPABASE_URL and PUBLIC_SUPABASE_ANON_KEY to enable sign-in';
      return;
    }

    authButton.textContent = signedIn ? 'Sign out' : 'Sign in';
    authButton.title = signedIn && label ? `Signed in as ${label}` : 'Sign in with GitHub';
  }

  authButton?.addEventListener('click', async () => {
    if (signedIn) {
      await signOut();
      return;
    }

    await signInWithGitHub(`${window.location.pathname}${window.location.search}`);
  });

  getCurrentSession().then((session) => {
    signedIn = !!session?.user;
    const label = (session?.user?.user_metadata?.user_name as string | undefined) || session?.user?.email || undefined;
    syncAuthButton(label);
  });

  onAuthStateChange((_event, session) => {
    signedIn = !!session?.user;
    const label = (session?.user?.user_metadata?.user_name as string | undefined) || session?.user?.email || undefined;
    syncAuthButton(label);
  });

  syncFavoritesCount();
  onFavoritesChanged(() => syncFavoritesCount());
</script>
