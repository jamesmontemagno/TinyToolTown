---
interface Props {
  totalTools: number;
}

const { totalTools } = Astro.props;
---

<section class="hero">
  <div class="container hero-inner">
    <div class="hero-sparkles">
      <span class="sparkle s1">✨</span>
      <span class="sparkle s2">⭐</span>
      <span class="sparkle s3">✨</span>
      <span class="sparkle s4">💫</span>
      <span class="sparkle s5">⭐</span>
    </div>
    <div class="hero-town">
      <span class="building">🏠</span>
      <span class="building">🏡</span>
      <span class="building">🏘️</span>
      <span class="building">🏠</span>
      <span class="building">🏡</span>
    </div>
    <h1 class="hero-title">
      Welcome to <span class="gradient-text">Tiny Tool Town</span>
    </h1>
    <p class="hero-subtitle">
      A place for <strong>stupid-delightful</strong> tools made with love.<br>
      Free, fun & open source. Made for an audience of one.
    </p>
    <div class="hero-cta">
      <a href="/tools/" class="btn btn-primary">Browse the Town 🏘️</a>
      <a href="/submit/" class="btn btn-secondary">Submit Your Tool ✨</a>
    </div>
    <div class="hero-counter" aria-label={`${totalTools} tiny tools listed in Tiny Tool Town`}>
      <div class="hero-counter-badge" aria-hidden="true">🏘️</div>
      <div class="hero-counter-copy">
        <p class="hero-counter-label">Tiny tools in town</p>
        <p class="hero-counter-value">
          <span class="hero-counter-number-chip">
            <span class="hero-counter-number" data-counter-target={totalTools}>{totalTools}</span>
          </span>
          <span class="hero-counter-suffix">and counting</span>
        </p>
      </div>
    </div>
    <p class="hero-manifesto">
      Vibe coding is the GeoCities of the AI era — and this is the neighborhood.
    </p>
  </div>
</section>

<style>
  .hero {
    padding: 4rem 0 3rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle at 30% 50%, rgba(255, 137, 6, 0.08) 0%, transparent 50%),
                radial-gradient(circle at 70% 50%, rgba(61, 169, 252, 0.06) 0%, transparent 50%);
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
  }

  .hero-sparkles {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .sparkle {
    position: absolute;
    animation: sparkle-float 4s ease-in-out infinite;
    font-size: 1.2rem;
    opacity: 0.6;
  }

  .s1 { top: 10%; left: 15%; animation-delay: 0s; }
  .s2 { top: 20%; right: 20%; animation-delay: 0.8s; }
  .s3 { top: 60%; left: 10%; animation-delay: 1.6s; }
  .s4 { top: 40%; right: 10%; animation-delay: 2.4s; }
  .s5 { bottom: 10%; left: 30%; animation-delay: 3.2s; }

  @keyframes sparkle-float {
    0%, 100% { transform: translateY(0) scale(1); opacity: 0.4; }
    50% { transform: translateY(-15px) scale(1.2); opacity: 0.8; }
  }

  .hero-town {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    display: flex;
    justify-content: center;
    gap: 0.5rem;
  }

  .building {
    display: inline-block;
    animation: building-pop 0.6s ease-out backwards;
  }

  .building:nth-child(1) { animation-delay: 0.1s; }
  .building:nth-child(2) { animation-delay: 0.2s; }
  .building:nth-child(3) { animation-delay: 0.3s; font-size: 3rem; }
  .building:nth-child(4) { animation-delay: 0.4s; }
  .building:nth-child(5) { animation-delay: 0.5s; }

  @keyframes building-pop {
    from { transform: translateY(20px) scale(0); opacity: 0; }
    to { transform: translateY(0) scale(1); opacity: 1; }
  }

  .hero-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 900;
    line-height: 1.1;
    margin-bottom: 1rem;
  }

  .hero-subtitle {
    font-size: 1.2rem;
    color: var(--color-text-muted);
    max-width: 600px;
    margin: 0 auto 2rem;
    line-height: 1.6;
  }

  .hero-subtitle strong {
    color: var(--color-primary);
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }

  .hero-counter {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    margin: 0 auto 1.75rem;
    padding: 0.55rem 0.7rem 0.55rem 0.6rem;
    border-radius: 999px;
    border: 2px solid var(--color-border);
    background: color-mix(in srgb, var(--color-bg-card) 84%, transparent);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.06),
      0 12px 30px rgba(8, 8, 20, 0.18);
    backdrop-filter: blur(10px);
  }

  .hero-counter-badge {
    width: 2.65rem;
    height: 2.65rem;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
    color: var(--color-bg);
    font-size: 1.2rem;
    box-shadow: 0 8px 20px rgba(242, 95, 76, 0.22);
    flex-shrink: 0;
  }

  .hero-counter-copy {
    text-align: left;
  }

  .hero-counter-label {
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 0.22rem;
  }

  .hero-counter-value {
    display: flex;
    align-items: baseline;
    gap: 0.45rem;
    flex-wrap: wrap;
  }

  .hero-counter-number-chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 4.5rem;
    padding: 0.4rem 0.75rem;
    border-radius: 999px;
    background: linear-gradient(135deg, rgba(61, 169, 252, 0.18), rgba(229, 49, 112, 0.12));
    border: 1px solid rgba(61, 169, 252, 0.18);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }

  .hero-counter-number {
    font-size: clamp(1.25rem, 3vw, 1.7rem);
    line-height: 1;
    font-weight: 900;
    color: var(--color-text);
    font-variant-numeric: tabular-nums;
  }

  .hero-counter-suffix {
    color: var(--color-accent);
    font-weight: 700;
    font-size: 0.95rem;
  }

  .hero-manifesto {
    font-style: italic;
    color: var(--color-text-muted);
    opacity: 0.7;
    font-size: 0.95rem;
  }

  @media (max-width: 640px) {
    .hero { padding: 2.5rem 0 2rem; }
    .hero-town { font-size: 2rem; }
    .building:nth-child(3) { font-size: 2.5rem; }
    .hero-subtitle { font-size: 1.05rem; }
    .hero-counter {
      width: min(100%, 24rem);
      border-radius: 999px;
      padding: 0.65rem 0.75rem;
      justify-content: center;
    }
    .hero-counter-copy {
      text-align: center;
    }
    .hero-counter-value {
      justify-content: center;
    }
  }
</style>

<script>
  const counters = document.querySelectorAll<HTMLElement>('.hero-counter-number');

  const animateCounter = (element: HTMLElement) => {
    const target = Number(element.dataset.counterTarget ?? '0');
    if (!Number.isFinite(target) || element.dataset.counterAnimated === 'true') {
      return;
    }

    element.dataset.counterAnimated = 'true';
    const duration = 1400;
    const startTime = performance.now();

    const update = (now: number) => {
      const progress = Math.min((now - startTime) / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      const value = Math.round(target * eased);
      element.textContent = value.toLocaleString();

      if (progress < 1) {
        requestAnimationFrame(update);
      }
    };

    requestAnimationFrame(update);
  };

  const observer = new IntersectionObserver((entries, instance) => {
    for (const entry of entries) {
      if (!entry.isIntersecting) {
        continue;
      }

      animateCounter(entry.target as HTMLElement);
      instance.unobserve(entry.target);
    }
  }, { threshold: 0.6 });

  for (const counter of counters) {
    counter.textContent = '0';
    observer.observe(counter);
  }
</script>
