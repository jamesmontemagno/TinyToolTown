---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ToolCard from '../components/ToolCard.astro';
import { getCollection } from 'astro:content';
import { getGitHubRepo, fetchStarCounts } from '../lib/github';

const allTools = await getCollection('tools');

const repoMap = new Map<string, string>();
for (const tool of allTools) {
  const repo = getGitHubRepo(tool.data.github_url);
  if (repo) repoMap.set(tool.id, repo);
}

const starCounts = await fetchStarCounts([...repoMap.values()]);
const toolStars = new Map<string, number>();
for (const [slug, repo] of repoMap) {
  toolStars.set(slug, starCounts.get(repo) || 0);
}

const tools = allTools.sort((a, b) =>
  new Date(b.data.date_added).getTime() - new Date(a.data.date_added).getTime()
);
---

<BaseLayout title="My Favorites — Tiny Tool Town 🏘️" description="Your saved favorite tools in Tiny Tool Town.">
  <Header />

  <main id="main" class="container favorites-page">
    <section class="favorites-header">
      <h1>My Favorites ❤</h1>
      <p id="favorites-subtitle">Loading your saved tools...</p>
      <p id="favorites-auth-status" class="auth-status">Local favorites only.</p>
      <button id="favorites-auth-button" class="auth-button">Sign in with GitHub to sync</button>
      <a href="/tools/" class="browse-link">Browse all tools →</a>
    </section>

    <div class="tool-grid" id="favorites-grid">
      {tools.map(tool => (
        <div
          class="tool-item"
          data-tool-id={tool.id.replace(/\.md$/, '')}
          data-date-added={tool.data.date_added}
        >
          <ToolCard
            name={tool.data.name}
            slug={tool.id.replace(/\.md$/, '')}
            tagline={tool.data.tagline}
            author={tool.data.author}
            author_github={tool.data.author_github}
            tags={tool.data.tags}
            language={tool.data.language}
            featured={tool.data.featured}
            thumbnail={tool.data.thumbnail}
            github_url={tool.data.github_url}
            stars={toolStars.get(tool.id) ?? undefined}
          />
        </div>
      ))}
    </div>

    <div id="empty-state" class="empty-state" style="display: none;" aria-live="polite">
      <p>No favorites yet. Save tools from Browse, Shorts, or a tool page.</p>
    </div>
  </main>

  <Footer />
</BaseLayout>

<script>
  import { getCurrentSession, isSupabaseConfigured, onAuthStateChange, signInWithGitHub } from '../lib/auth';
  import { getFavoriteIds, onFavoritesChanged } from '../lib/favorites';

  const subtitle = document.getElementById('favorites-subtitle');
  const authStatus = document.getElementById('favorites-auth-status');
  const authButton = document.getElementById('favorites-auth-button') as HTMLButtonElement | null;
  const authEnabled = isSupabaseConfigured();
  const grid = document.getElementById('favorites-grid');
  const emptyState = document.getElementById('empty-state');
  const items = Array.from(document.querySelectorAll<HTMLElement>('.tool-item[data-tool-id]'));

  function applyFavorites() {
    if (!grid || !subtitle || !emptyState) return;

    const favorites = new Set(getFavoriteIds());
    let visible = 0;

    items.forEach((item) => {
      const toolId = item.dataset.toolId || '';
      const show = favorites.has(toolId);
      item.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    subtitle.textContent = visible === 0
      ? 'No saved tools yet'
      : `${visible} saved ${visible === 1 ? 'tool' : 'tools'}`;

    emptyState.style.display = visible === 0 ? 'block' : 'none';
  }

  function updateAuthState(session: Awaited<ReturnType<typeof getCurrentSession>>) {
    if (!authEnabled) {
      if (authStatus) {
        authStatus.textContent = 'Sync unavailable (Supabase is not configured).';
      }
      if (authButton) authButton.hidden = true;
      return;
    }

    const signedIn = !!session?.user;
    if (authStatus) {
      if (signedIn) {
        const label = (session?.user?.user_metadata?.user_name as string | undefined) || session?.user?.email || 'your account';
        authStatus.textContent = `Sync enabled for ${label}.`;
      } else {
        authStatus.textContent = 'Local favorites only.';
      }
    }

    if (authButton) {
      authButton.hidden = signedIn;
    }
  }

  authButton?.addEventListener('click', async () => {
    await signInWithGitHub(`${window.location.pathname}${window.location.search}`);
  });

  applyFavorites();
  onFavoritesChanged(() => applyFavorites());
  getCurrentSession().then((session) => updateAuthState(session));
  onAuthStateChange((_event, session) => updateAuthState(session));
</script>

<style>
  .favorites-page {
    padding: 2rem 0 3rem;
  }

  .favorites-header {
    margin-bottom: 1.5rem;
  }

  .favorites-header h1 {
    font-size: 2rem;
    font-weight: 900;
    margin-bottom: 0.25rem;
  }

  .favorites-header p {
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }

  .browse-link {
    color: var(--color-primary);
    font-weight: 600;
    display: inline-block;
    margin-top: 0.6rem;
  }

  .auth-status {
    font-size: 0.92rem;
    margin-bottom: 0.65rem;
  }

  .auth-button {
    border: 1px solid var(--color-border);
    background: var(--color-bg-card);
    color: var(--color-text);
    border-radius: 999px;
    padding: 0.45rem 0.9rem;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s;
  }

  .auth-button:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .tool-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .empty-state {
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    margin-top: 1.5rem;
    text-align: center;
    color: var(--color-text-muted);
  }
</style>
