---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ToolCard from '../../components/ToolCard.astro';
import { getCollection } from 'astro:content';

const tools = await getCollection('tools');
const sortedTools = tools.sort((a, b) =>
  new Date(b.data.date_added).getTime() - new Date(a.data.date_added).getTime()
);
---

<BaseLayout title="My Favorites — Tiny Tool Town 🏘️" description="Your saved tools in Tiny Tool Town.">
  <Header />

  <main id="main" class="container">
    <section class="favorites-header">
      <h1>My Favorites</h1>
      <p id="favorites-subtitle" class="favorites-subtitle">Loading your saved tools...</p>
    </section>

    <div class="tool-grid" id="favorites-grid">
      {sortedTools.map((tool) => (
        <div class="favorite-item" data-slug={tool.id.replace(/\.md$/, '')}>
          <ToolCard
            name={tool.data.name}
            slug={tool.id.replace(/\.md$/, '')}
            tagline={tool.data.tagline}
            author={tool.data.author}
            author_github={tool.data.author_github}
            tags={tool.data.tags}
            language={tool.data.language}
            featured={tool.data.featured}
            thumbnail={tool.data.thumbnail}
            github_url={tool.data.github_url}
          />
        </div>
      ))}
    </div>

    <div id="no-favorites" class="empty-state" style="display:none;">
      <h2>No favorites yet</h2>
      <p>Save tools from Browse, tool detail pages, or Shorts, and they will show up here.</p>
      <a class="btn btn-primary" href="/tools/">Explore tools</a>
    </div>
  </main>

  <Footer />
</BaseLayout>

<script>
  import { getFavoriteSlugs, initClientState, subscribeClientState } from '../../lib/client-state';

  const items = document.querySelectorAll('.favorite-item');
  const subtitle = document.getElementById('favorites-subtitle');
  const emptyState = document.getElementById('no-favorites');

  function renderFavorites() {
    const favorites = new Set(getFavoriteSlugs());
    let visible = 0;

    items.forEach((item) => {
      const slug = (item as HTMLElement).dataset.slug || '';
      const show = favorites.has(slug);
      (item as HTMLElement).style.display = show ? '' : 'none';
      if (show) visible += 1;
    });

    if (subtitle) {
      subtitle.textContent = visible === 0 ? 'No saved tools yet.' : `${visible} saved tool${visible === 1 ? '' : 's'}`;
    }

    if (emptyState) {
      emptyState.style.display = visible === 0 ? 'block' : 'none';
    }
  }

  void initClientState().then(() => {
    renderFavorites();
    subscribeClientState(() => renderFavorites());
  });
</script>

<style>
  .favorites-header {
    padding: 2.5rem 0 1.5rem;
  }

  .favorites-header h1 {
    font-size: 2rem;
    font-weight: 900;
  }

  .favorites-subtitle {
    margin-top: 0.3rem;
    color: var(--color-text-muted);
  }

  .tool-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .empty-state {
    max-width: 550px;
    margin: 2.5rem auto 3rem;
    text-align: center;
    padding: 2rem;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    background: var(--color-bg-card);
  }

  .empty-state h2 {
    font-size: 1.4rem;
    margin-bottom: 0.6rem;
  }

  .empty-state p {
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }
</style>
